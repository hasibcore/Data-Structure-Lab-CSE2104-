#include<bits/stdc++.h>
using namespace std;
void merge(vector<int>&v,int low,int mid,int high)
{
    int i=low;
    int j=mid+1;
    int k=low;
    vector<int>temp;
    while(i<=mid && j<=high)
    {
        if(v[i]<=v[j])
        {
            temp.push_back(v[i]);
            i++;
            k++;
        }
        else{
            temp.push_back(v[j]);
            j++;
            k++;
        }
    }
    if(i>mid)
    {
        while(j<=high)
        {
            temp.push_back(v[j]);
            j++;
            k++;
        }
    }
    else{
        while(i<=mid)
    {
        temp.push_back(v[i]);
            i++;
            k++;
    }
    }
    for(int i=0;i<=high;i++)
    {
        v[i]=temp[i];
    }

}
void mergeSort(vector<int>&v,int low,int high)
{
  if(high>low)
{
  int mid=(low+high)/2;
    mergeSort(v,low,mid);
    mergeSort(v,mid+1,high);
merge(v,low,mid,high);
}

}


int main()
{
  int n;
    cin>>n;
        vector<int>v;
        for(int i=0;i<n;i++)
        {
            int x;
            cin>>x;
            v.push_back(x);
        }
        mergeSort(v,0,n-1);


}